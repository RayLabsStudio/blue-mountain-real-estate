---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE } from '~/lib/site';
import { organizationLd, localBusinessLd, serviceLd } from '~/lib/seo';

const description =
  'Blue Mountain Real Estate is a licensed Florida brokerage and property management firm. We help families buy and sell homes, and manage rental and investment properties end-to-end.';

const services = [
  {
    icon: 'key',
    title: 'Buy a Home',
    body: 'Single-family, condo, or investment — we represent buyers across Florida with market research, financing referrals, negotiation, and closing coordination.',
    cta: 'Start a search',
    image:
      'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=80',
    alt: 'White two-story coastal Florida home with wrap-around porch, palms, and pool.',
  },
  {
    icon: 'sign',
    title: 'Sell a Home',
    body: 'Pricing, staging guidance, professional photography, MLS listing, and active negotiation. We market your property to qualified buyers, not just any walk-in.',
    cta: 'Get a market analysis',
    image:
      'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&w=1200&q=80',
    alt: 'Single-family home with manicured lawn, ready to list.',
  },
  {
    icon: 'building',
    title: 'Rental & Property Management',
    body: 'Tenant screening, leasing, rent collection, maintenance coordination, and monthly owner reporting. Hands-off ownership for landlords and out-of-state investors.',
    cta: 'Discuss management',
    image:
      'https://images.unsplash.com/photo-1560185007-cde436f6a4d0?auto=format&fit=crop&w=1200&q=80',
    alt: 'Bright, professionally staged interior of a managed rental property.',
  },
] as const;

const reasons = [
  {
    title: 'Licensed Florida Brokerage',
    body: 'Member of Florida Realtors® and the National Association of Realtors. Full E&O coverage, transparent commissions, fiduciary representation.',
  },
  {
    title: 'Owner-Operated',
    body: 'You work with the principals — not a junior agent buried inside a 200-agent franchise. Decisions get made and communicated quickly.',
  },
  {
    title: 'Sister-Company Network',
    body: 'Affiliated with Senior Income Properties and Florida Tradition Builders. If your transaction touches construction, renovation, or elder-law strategy, we have the bench.',
  },
  {
    title: 'No High-Pressure Pitch',
    body: 'We tell you when not to buy, when to wait, when a price is wrong. If the deal isn\'t right for you, it isn\'t right for us.',
  },
] as const;

const servicesLd = services.map((s) =>
  serviceLd({
    name: s.title,
    description: s.body,
    serviceType: s.title,
  })
);
---

<BaseLayout
  title={undefined}
  description={description}
  jsonLd={[organizationLd(), localBusinessLd(), ...servicesLd]}
>
  <!-- 1 · HERO — Marquee, full-bleed coastal photo -->
  <section class="hero section--deep">
    <div class="hero__photo" aria-hidden="true"></div>
    <div class="container hero__inner">
      <span class="eyebrow hero__eyebrow">{SITE.tagline}</span>
      <h1 class="display-xl hero__title">
        Florida coast living, <em>handled with care.</em>
      </h1>
      <p class="hero__lede">
        Licensed brokerage and property management for Florida buyers, sellers, and landlords.
        Local expertise, full-service handling, no high-pressure pitch.
      </p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="#contact">Get a Free Consultation</a>
        <a class="btn btn--secondary" href="#services">Explore Our Services</a>
      </div>
    </div>
    <div class="hero__trust">
      <div class="container hero__trust-inner">
        <span class="hero__trust-item">Licensed Florida Brokerage</span>
        <span class="hero__trust-dot" aria-hidden="true"></span>
        <span class="hero__trust-item">Member · {SITE.brokerage.membership}</span>
        <span class="hero__trust-dot" aria-hidden="true"></span>
        <span class="hero__trust-item">Owner-Operated · 30+ Years</span>
      </div>
    </div>
  </section>

  <!-- 2 · SERVICES — large image-led cards -->
  <section id="services" class="section">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">What we do</span>
        <h2 class="display-m section-head__title">Three things. Done well.</h2>
        <p class="section-head__lede">
          Buying, selling, or renting — every track gets full attention from a licensed agent who
          handles the work themselves, start to finish.
        </p>
      </header>

      <ul class="services-grid services-grid--3">
        {services.map((s) => (
          <li class="service-card">
            <div class="service-card__media">
              <img
                src={s.image}
                alt={s.alt}
                width="1200"
                height="750"
                loading="lazy"
                decoding="async"
              />
              <span class="service-card__icon" aria-hidden="true">
                {s.icon === 'key' && (
                  <svg viewBox="0 0 32 32" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="10" cy="22" r="5" />
                    <path d="M14 18 L26 6" />
                    <path d="M22 10 L26 6 L28 8" />
                    <path d="M18 14 L21 11" />
                  </svg>
                )}
                {s.icon === 'sign' && (
                  <svg viewBox="0 0 32 32" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="10" y1="6" x2="10" y2="28" />
                    <rect x="10" y="8" width="16" height="10" />
                    <path d="M4 28 L28 28" />
                  </svg>
                )}
                {s.icon === 'building' && (
                  <svg viewBox="0 0 32 32" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="6" y="4" width="20" height="24" />
                    <line x1="11" y1="10" x2="13" y2="10" />
                    <line x1="19" y1="10" x2="21" y2="10" />
                    <line x1="11" y1="16" x2="13" y2="16" />
                    <line x1="19" y1="16" x2="21" y2="16" />
                    <line x1="14" y1="28" x2="14" y2="22" />
                    <line x1="18" y1="28" x2="18" y2="22" />
                  </svg>
                )}
              </span>
            </div>
            <div class="service-card__body-wrap">
              <h3 class="service-card__title">{s.title}</h3>
              <p class="service-card__body">{s.body}</p>
              <a class="service-card__link" href="#contact">{s.cta} →</a>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 3 · WHY US — split: large coastal image + reasons -->
  <section id="why-us" class="section">
    <div class="container why-us__layout">
      <figure class="why-us__media">
        <img
          src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&w=1400&q=80"
          alt="Light-filled open-plan living room of a Florida coastal home."
          width="1400"
          height="1750"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <div class="why-us__content">
        <header class="section-head">
          <span class="eyebrow">Why Blue Mountain</span>
          <h2 class="display-m section-head__title">What working with us actually looks like.</h2>
        </header>

        <ul class="reasons-grid">
          {reasons.map((r) => (
            <li class="reason">
              <span class="reason__check" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12 L10 17 L19 7" />
                </svg>
              </span>
              <div>
                <h3 class="reason__title">{r.title}</h3>
                <p class="reason__body">{r.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- 3.5 · COASTAL STATEMENT BAND — full-bleed sunset -->
  <section class="statement-band section--deep">
    <div
      class="statement-band__photo"
      style="background-image: url('https://images.unsplash.com/photo-1605723517503-3cadb5818a0c?auto=format&fit=crop&w=2400&q=85')"
    ></div>
    <div class="container statement-band__inner">
      <span class="eyebrow">Florida coast · sunrise to sunset</span>
      <p class="statement-band__quote">
        We work the deals we take all the way through — not the volume, the outcome.
      </p>
    </div>
  </section>

  <!-- 4 · ABOUT — large framed photo + prose -->
  <section id="about" class="section">
    <div class="container about__layout">
      <figure class="about-photo">
        <img
          src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=1600&q=80"
          alt="The Blue Mountain Real Estate team — Florida-licensed agents."
          width="1600"
          height="1100"
          loading="lazy"
          decoding="async"
        />
        <figcaption>Our Florida agents — licensed, local, and accountable.</figcaption>
      </figure>

      <div class="about__body">
        <header class="section-head">
          <span class="eyebrow">About us</span>
          <h2 class="display-m section-head__title">Florida-based. Florida-focused.</h2>
        </header>

        <div class="prose">
          <p>
            Blue Mountain Real Estate is a Florida-licensed residential brokerage and property
            management firm, founded by AJ Bedizel — a four-state licensed broker and Florida
            certified general contractor with over 30 years across real estate investments,
            construction, and property operations.
          </p>
          <p>
            We're part of a small family of sister companies: <a href={SITE.sister.seniorIncomeProperties}>
            Senior Income Properties</a> handles attorney-directed real estate for elder-law and
            Medicaid-focused planning, and <a href={SITE.sister.floridaTraditionBuilders}>
            Florida Tradition Builders</a> handles custom coastal construction. When your transaction
            touches multiple disciplines, we coordinate them in-house.
          </p>
          <p>
            We work with families, individual investors, and out-of-state owners who want a
            hands-off relationship with a Florida property. We don't churn listings, we don't
            chase volume — we work the deals we take all the way through.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5 · CONTACT (email-based) -->
  <section id="contact" class="section">
    <div class="container">
      <header class="section-head section-head--center">
        <span class="eyebrow">Get in touch</span>
        <h2 class="display-m section-head__title">Connect with our Florida experts.</h2>
        <p class="section-head__lede">
          Send a short email and we'll get back the same business day to talk through your property
          goals. No obligation, no high-pressure pitch.
        </p>
      </header>

      <div class="contact-grid">
        <article class="channel channel--primary">
          <span class="eyebrow">Florida Licensed</span>
          <h3 class="channel__title">Licensed & represented.</h3>
          <p class="channel__lede">
            Licensed Florida real estate brokerage with full E&O coverage and fiduciary
            representation on every transaction. Member of the state and national associations.
          </p>
          <div class="channel__value-row">
            <div class="channel__value channel__value--phone" aria-label={`Member ${SITE.brokerage.membership}`}>
              <span>{SITE.brokerage.membership}</span>
            </div>
          </div>
          <dl class="channel__meta">
            <div>
              <dt>Brokerage</dt>
              <dd>{SITE.brokerage.description}</dd>
            </div>
            <div>
              <dt>Coverage</dt>
              <dd>E&O insurance on every transaction</dd>
            </div>
          </dl>
        </article>

        <article class="channel">
          <span class="eyebrow">Email</span>
          <h3 class="channel__title">Send us a note.</h3>
          <p class="channel__lede">
            Prefer writing first? Email a short summary — what you're looking for, your timeline,
            the area you're focused on. We'll reply by phone, typically within one business day.
          </p>
          <div class="channel__value-row">
            <a class="channel__value channel__value--email" href={`mailto:${SITE.email}?subject=Real%20estate%20inquiry%20%E2%80%94%20Blue%20Mountain%20Real%20Estate`}>
              <span>{SITE.email}</span>
            </a>
            <button
              type="button"
              class="channel__copy"
              data-copy={SITE.email}
              aria-label={`Copy email address ${SITE.email}`}
              title="Copy to clipboard"
            >
              <svg class="channel__copy-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
              </svg>
              <svg class="channel__copy-check" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 13 L9 17 L19 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="vh">Copy email address</span>
              <span class="channel__copy-toast" aria-hidden="true">Copied</span>
            </button>
          </div>
          <dl class="channel__meta">
            <div>
              <dt>Response</dt>
              <dd>Within one business day</dd>
            </div>
            <div>
              <dt>Best for</dt>
              <dd>Sharing details, attaching documents</dd>
            </div>
          </dl>
        </article>
      </div>

      <div class="prep">
        <span class="eyebrow">Before the call</span>
        <h3 class="display-m prep__title">A few things that make the first call more useful.</h3>
        <p class="prep__lede">
          None of this is required — but if you have it ready, we can give you a real answer faster.
        </p>
        <ul class="prep__list">
          {[
            'Buying, selling, renting, or property management',
            'Property address or the area you\'re focused on',
            'Approximate budget or price range',
            'Timeline — when do you want to move',
            'Financing pre-approval status (for buyers)',
            'Current rental occupancy (for owners)',
          ].map((item) => (
            <li>
              <span class="prep__check" aria-hidden="true">
                <svg viewBox="0 0 16 14" width="12" height="10" fill="none">
                  <path d="M2 8.5 L6 12.5 L14 1.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    const value = btn.dataset.copy;
    if (!value) return;
    let timer: number | undefined;
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(value);
        btn.classList.add('is-done');
        if (timer) window.clearTimeout(timer);
        timer = window.setTimeout(() => {
          btn.classList.remove('is-done');
        }, 1800);
      } catch {
        const link = btn.previousElementSibling?.querySelector('span');
        if (link) {
          const range = document.createRange();
          range.selectNodeContents(link);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
      }
    });
  });
</script>

<style>
  /* Hallmark · macrostructure: Marquee Hero · genre: atmospheric (coastal-luxury)
   * tone: luxury · theme: custom (warm cream + coastal navy, sunset-coral accent)
   * anchor hue: navy 255° · accent-warm: sunset-coral 45°
   * pre-emit critique: P5 H5 E5 S4 R4 V5
   */

  /* ── Hero — Marquee, full-bleed coastal photo ─────── */
  .hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(560px, 84vh, 780px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-block: var(--space-4xl) 0;
    overflow: hidden;
    background: var(--color-paper-deep);
  }

  .hero__photo {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(
        86deg,
        var(--scrim-1) 0%,
        var(--scrim-2) 46%,
        var(--scrim-3) 100%
      ),
      linear-gradient(0deg, var(--scrim-1) 0%, transparent 42%),
      url('https://images.unsplash.com/photo-1613490493576-7fde63acd811?auto=format&fit=crop&w=2400&q=85')
        center/cover no-repeat,
      var(--color-paper-deep);
  }

  .hero__inner {
    /* Full container width, left-aligned to the page gutter (matches the nav
     * + trust strip). Headline/lede cap their own width by character count, so
     * the text stays tight without a centered narrow column. */
    padding-bottom: var(--space-2xl);
  }

  .hero__eyebrow {
    color: var(--color-accent-warm);
    letter-spacing: 0.24em;
  }

  .hero__title {
    color: var(--color-ink-on-deep);
    margin-top: var(--space-xs);
    line-height: 1.04;
    letter-spacing: -0.02em;
    max-width: 18ch;
    font-style: normal;
  }

  .hero__title em {
    /* Emphasis carried by the italic alone, in warm sand — not loud coral.
     * Coral stays on small accents only (eyebrow tick, icons, links). */
    color: var(--color-sand);
    font-style: italic;
    font-weight: 700;
  }

  .hero__lede {
    color: var(--color-ink-on-deep);
    opacity: 0.92;
    margin-top: var(--space-md);
    font-size: var(--text-md);
    line-height: 1.65;
    max-width: 50ch;
    text-shadow: 0 1px 16px oklch(15% 0.05 255 / 0.45);
  }

  .hero__cta {
    margin-top: var(--space-lg);
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  /* Hero trust strip — pinned bottom of the marquee */
  .hero__trust {
    border-top: var(--rule-hair) solid oklch(100% 0 0 / 0.16);
    background: oklch(15% 0.05 255 / 0.42);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .hero__trust-inner {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-md);
    padding-block: var(--space-sm);
    font-family: var(--font-outlier);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-ink-on-deep);
  }

  .hero__trust-item {
    opacity: 0.86;
  }

  .hero__trust-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent-warm);
    flex-shrink: 0;
  }

  /* ── Section head ────────────────────────────────── */
  .section-head {
    max-width: 56ch;
    margin-bottom: var(--space-xl);
  }

  .section-head--center {
    margin-inline: auto;
    text-align: center;
  }

  .section-head__title {
    margin-top: var(--space-xs);
    line-height: 1.12;
    letter-spacing: -0.01em;
  }

  .section-head__lede {
    margin-top: var(--space-md);
    color: var(--color-ink-2);
    line-height: 1.65;
    font-size: var(--text-md);
  }

  /* ── Services — image-led cards ──────────────────── */
  .services-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-lg);
  }

  .services-grid--3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .service-card {
    background: var(--color-paper-2);
    border: var(--rule-hair) solid var(--color-rule-2);
    border-radius: var(--radius-card-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-card);
    transition: transform var(--dur-med) var(--ease-out), box-shadow var(--dur-med) var(--ease-out);
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-img);
  }

  .service-card__media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-paper-3);
  }

  .service-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-long) var(--ease-out);
  }

  .service-card:hover .service-card__media img {
    transform: scale(1.04);
  }

  .service-card__icon {
    position: absolute;
    left: var(--space-md);
    bottom: var(--space-md);
    width: 44px;
    height: 44px;
    color: var(--color-accent-warm-ink);
    background: var(--color-accent-warm);
    display: grid;
    place-items: center;
    border-radius: var(--radius-card);
    box-shadow: 0 6px 16px -6px oklch(20% 0.06 255 / 0.5);
  }

  .service-card__body-wrap {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .service-card__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-ink);
    line-height: 1.2;
  }

  .service-card__body {
    color: var(--color-ink-2);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .service-card__link {
    margin-top: auto;
    padding-top: var(--space-sm);
    color: var(--color-accent);
    font-weight: 600;
    font-size: var(--text-sm);
    border-bottom: 0;
  }

  .service-card__link:hover {
    color: var(--color-accent-2);
  }

  /* ── Why us — split image + reasons ──────────────── */
  .why-us__layout {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: var(--space-2xl);
    align-items: center;
  }

  .why-us__media {
    margin: 0;
    border-radius: var(--radius-img);
    overflow: hidden;
    box-shadow: var(--shadow-img);
    align-self: stretch;
  }

  .why-us__media img {
    width: 100%;
    height: 100%;
    min-height: 100%;
    object-fit: cover;
    display: block;
  }

  .reasons-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .reason {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-sm);
    align-items: start;
  }

  .reason__check {
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    background: var(--color-accent-warm);
    color: var(--color-accent-warm-ink);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .reason__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-ink);
    margin-bottom: var(--space-3xs);
  }

  .reason__body {
    color: var(--color-ink-2);
    font-size: var(--text-base);
    line-height: 1.6;
  }

  /* ── Coastal statement band — full-bleed sunset ──── */
  .statement-band {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding-block: var(--space-4xl);
    display: flex;
    align-items: center;
