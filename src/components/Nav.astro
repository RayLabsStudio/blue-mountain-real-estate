---
import { SITE } from '~/lib/site';

const NAV = [
  { href: '#services', label: 'Services' },
  { href: '#why-us', label: 'Why Us' },
  { href: '#about', label: 'About' },
  { href: '#contact', label: 'Contact' },
] as const;
---

<header class="site-header">
  <div class="container brand-rail__inner">
    <a class="brand" href="/" aria-label={`${SITE.name} — home`}>
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 25 L11 14 L16 19 L21 11 L29 25 Z" />
          <circle cx="22" cy="7" r="2.5" fill="currentColor" stroke="none" />
        </svg>
      </span>
      <span class="brand__text">
        <span class="brand__name">Blue Mountain</span>
        <span class="brand__sub">Real Estate</span>
      </span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <button
        class="primary-nav__toggle"
        type="button"
        aria-controls="primary-nav-list"
        aria-expanded="false"
        data-nav-toggle
      >
        <span class="primary-nav__toggle-icon" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
        <span class="primary-nav__toggle-label">Menu</span>
      </button>
      <ul id="primary-nav-list" class="primary-nav__list" data-nav-list>
        {NAV.map((item) => (
          <li class="primary-nav__item">
            <a href={item.href} class="primary-nav__link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <a class="btn btn--primary brand-contact__cta" href="#contact">Get a Free Consultation</a>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const list = document.querySelector<HTMLElement>('[data-nav-list]');
  if (toggle && list) {
    const setOpen = (open: boolean) => {
      list.classList.toggle('is-open', open);
      toggle.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
    };
    toggle.addEventListener('click', () => setOpen(!list.classList.contains('is-open')));
    list.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && list.classList.contains('is-open')) setOpen(false);
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklch, var(--color-paper-2) 96%, transparent);
    backdrop-filter: saturate(180%) blur(10px);
    -webkit-backdrop-filter: saturate(180%) blur(10px);
    border-bottom: var(--rule-hair) solid var(--color-rule);
  }

  .brand-rail__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-block: var(--space-sm);
    flex-wrap: wrap;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-ink);
    min-width: 0;
  }

  .brand__mark {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    color: var(--color-accent);
  }

  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    min-width: 0;
  }

  .brand__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.0625rem;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }

  .brand__sub {
    font-family: var(--font-outlier);
    font-size: 0.6875rem;
    color: var(--color-ink-3);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 2px;
  }

  .primary-nav__toggle {
    display: none;
    background: transparent;
    border: 0;
    padding: var(--space-sm) 0;
    color: var(--color-ink);
    align-items: center;
    gap: var(--space-2xs);
    font-family: var(--font-outlier);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .primary-nav__toggle-icon {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    width: 18px;
  }

  .primary-nav__toggle-icon span {
    height: 1.5px;
    background: currentColor;
  }

  .primary-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-md);
    align-items: center;
  }

  .primary-nav__link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink-2);
    padding: var(--space-2xs) 0;
    position: relative;
    transition: color var(--dur-med) var(--ease-out);
  }

  .primary-nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1.5px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur-med) var(--ease-out);
  }

  .primary-nav__link:hover {
    color: var(--color-ink);
  }

  .primary-nav__link:hover::after {
    transform: scaleX(1);
  }

  .brand-contact__cta {
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    letter-spacing: 0.01em;
  }

  @media (max-width: 880px) {
    .primary-nav__toggle {
      display: inline-flex;
    }

    .primary-nav__list {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: var(--color-paper-2);
      padding: var(--space-md) var(--space-lg);
      gap: 0;
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--dur-med) var(--ease-out), transform var(--dur-med) var(--ease-out);
      border-bottom: var(--rule-hair) solid var(--color-rule);
      box-shadow: 0 12px 32px -8px oklch(20% 0.04 265 / 0.22);
    }

    .primary-nav__list.is-open {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .primary-nav__link {
      padding: var(--space-sm) 0;
      border-bottom: var(--rule-hair) solid var(--color-rule-2);
      font-size: var(--text-base);
      display: block;
    }

    .primary-nav__link::after { display: none; }
  }

  @media (max-width: 540px) {
    .brand-contact__cta {
      padding: 0.5rem 1rem;
      font-size: 0.75rem;
    }
    .brand__name { font-size: 1rem; }
  }
</style>
